{
  "name": "cantoral-pwa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Cantoral PWA — Vue 3 + Vite",
  "scripts": {
    "predev": "node scripts/build-songs-manifest.js && node scripts/build-icons.js",
    "dev": "vite --host",
    "prebuild": "node scripts/build-songs-manifest.js && node scripts/build-icons.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint src scripts --deny-warnings",
    "lint:fix": "oxlint src scripts --fix",
    "format": "prettier --write \"src/**/*.{js,vue,css,json,md}\" \"scripts/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.{js,vue,css,json,md}\" \"scripts/**/*.js\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "pinia": "^2.2.4",
    "vue": "^3.5.12",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/vue3-vite": "^10.3.5",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vitest/browser": "^2.1.4",
    "@vitest/coverage-v8": "^2.1.4",
    "jsdom": "^25.0.1",
    "oxlint": "^0.11.0",
    "playwright": "^1.59.1",
    "prettier": "^3.3.3",
    "sharp": "^0.34.5",
    "storybook": "^10.3.5",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^2.1.4"
  }
}
